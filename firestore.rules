rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" ||
        request.auth.uid == "Kb7jQGxp4pf1cjdfbMwz4HnujQi2" ||
        request.auth.uid == "CChLqb7OxdbbSpjNRKMAt2vJNa12"
      );
    }

    // USERS
    match /users/{userId} {
      // Autorise la liste pour l'admin afin de charger le dashboard utilisateurs
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // PARTNERS
    match /partners/{partnerId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == partnerId);
    }

    // LISTINGS
    match /listings/{listingId} {
      allow read: if true;
      allow create: if true; // Support Guest Mode
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // BOOKINGS
    match /bookings/{bookingId} {
      // Autorise la liste pour charger les dashboards (le filtrage réel se fait via la query client)
      allow list: if isSignedIn();
      
      allow get: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));

      // Autorise la création pour tous (Mode Invité supporté)
      allow create: if true;

      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));

      allow delete: if isAdmin();
    }

    // CONVERSATIONS
    match /conversations/{convId} {
      // Autorise la liste pour charger les messageries
      allow list: if isSignedIn();
      
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      
      allow create: if isSignedIn();
      
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);

      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // SETTINGS & CONFIG
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // STRIPE EXTENSION PATHS
    match /customers/{uid}/checkout_sessions/{id} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // ADMIN PRIORITAIRE (Accès global)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}