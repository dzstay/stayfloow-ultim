
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. DÉTECTION ADMIN MAÎTRE (STRICTE)
    // Synchronisé avec src/lib/admin-config.ts
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2"
      );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // ACCÈS PRIORITAIRE ADMIN
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 2. RÈGLES UTILISATEURS
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    match /bookings/{bookingId} {
      // Autoriser la lecture si l'utilisateur est le client, le partenaire ou l'admin
      // Utilisation de 'read' (get + list) pour une meilleure compatibilité des requêtes filtrées
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      );
      
      // Autoriser n'importe quel visiteur (invité) à créer une réservation
      allow create: if true; 
      
      // Seuls l'admin ou les parties concernées peuvent modifier
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      );
      
      allow delete: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read, write: if isSignedIn() && (request.auth.uid == partnerId || isAdmin());
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /conversations/{convId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      
      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          isAdmin() ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid])
        );
      }
    }
  }
}
