rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2"
      );
    }

    // USERS : Accès restreint au propriétaire ou admin
    match /users/{userId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // PARTNERS : Accès restreint au partenaire ou admin
    match /partners/{partnerId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == partnerId);
    }

    // LISTINGS : Lecture publique, création connecté, modification propriétaire
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // BOOKINGS : Autorise le listing pour les dashboards, restreint le get individuel
    match /bookings/{bookingId} {
      // Autoriser le listage global pour les utilisateurs connectés (le filtrage se fait via les queries)
      allow list: if isSignedIn();
      
      // Lecture individuelle réservée aux parties concernées
      allow get: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));

      allow create: if isSignedIn();
      
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));

      allow delete: if isAdmin();
    }

    // CONVERSATIONS : Autorise le listing, restreint l'accès au contenu
    match /conversations/{convId} {
      allow list: if isSignedIn();
      
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      
      allow create: if isSignedIn();
      
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);

      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read, create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // SETTINGS & CONFIG
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ADMIN PRIORITAIRE (Accès global)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}