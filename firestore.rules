rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ADMIN PRIORITAIRE (Accès total aux comptes maîtres)
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // USERS
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isOwner(userId);
    }

    // LISTINGS
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isAdmin() || resource.data.ownerId == request.auth.uid
      );
    }

    // PARTNERS
    match /partners/{partnerId} {
      allow read, update, delete: if isSignedIn() && (isAdmin() || request.auth.uid == partnerId);
      allow create: if isSignedIn() && request.auth.uid == partnerId;
    }

    // BOOKINGS
    match /bookings/{bookingId} {
      // Lecture autorisée pour le client, le partenaire ou l'admin
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      );

      // Création réservée aux utilisateurs connectés avec validation minimale
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.listingId is string
        && request.resource.data.startDate != null
        && request.resource.data.endDate != null;

      // Mise à jour limitée aux parties prenantes
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      );

      allow delete: if isAdmin();
    }

    // SETTINGS
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CONVERSATIONS
    match /conversations/{convId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid in resource.data.participants
      );

      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid in resource.data.participants
      );

      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
        );

        allow update, delete: if isAdmin();
      }
    }
  }
}