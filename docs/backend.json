
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "partner", "admin"] },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "firstName", "lastName"]
    },
    "PartnerListing": {
      "title": "PartnerListing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "category": { "type": "string", "enum": ["accommodation", "car_rental", "circuit"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "inactive"] },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "details": { "type": "object" },
        "location": { "type": "object" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "partnerId": { "type": "string" },
        "listingId": { "type": "string" },
        "itemName": { "type": "string" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "cancelled"] },
        "paymentId": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookingId": { "type": "string" },
        "amount": { "type": "number" },
        "commission": { "type": "number" },
        "partnerRevenue": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "User profiles" },
    "/listings/{listingId}": { "schema": { "$ref": "#/backend/entities/PartnerListing" }, "description": "Global listings" },
    "/bookings/{bookingId}": { "schema": { "$ref": "#/backend/entities/Booking" }, "description": "Reservations" },
    "/payments/{payId}": { "schema": { "$ref": "#/backend/entities/Payment" }, "description": "Financial transactions" },
    "/settings/siteConfig": { "schema": { "type": "object" }, "description": "Platform configuration" },
    "/adminLogs/{logId}": { "schema": { "type": "object" }, "description": "Admin action logs" }
  }
}
