
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" ||
        request.auth.uid == "Kb7jQGxp4pf1cjdfbMwz4HnujQi2" ||
        request.auth.uid == "CChLqb7OxdbbSpjNRKMAt2vJNa12" ||
        request.auth.uid == "3rixbVLeMaUARuODthz3ds80WeS2" ||
        request.auth.uid == "dqUISCFanPajTlrvC23iAXTr4BI2"
      );
    }

    // ADMIN - Accès total prioritaire
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // USERS - Lecture/Écriture par le propriétaire
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
    }

    // LISTINGS - Lecture publique, création par utilisateur connecté
    match /listings/{listingId} {
      allow read: if true;
      // Autoriser la création si l'utilisateur est connecté (Admin ou Partenaire)
      allow create: if isSignedIn();
      // Autoriser la modification si c'est le propriétaire ou un admin
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // BOOKINGS - Gestion des réservations
    match /bookings/{bookingId} {
      allow list: if isSignedIn();
      allow get: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));
      allow create: if true; 
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));
      allow delete: if isAdmin();
    }

    // PARTNERS - Profils professionnels
    match /partners/{partnerId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == partnerId);
    }

    // CONVERSATIONS - Messagerie
    match /conversations/{convId} {
      allow list: if isSignedIn();
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // SETTINGS - Configuration site
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // STRIPE & MAIL
    match /customers/{uid}/checkout_sessions/{id} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }
    match /mail/{mailId} {
      allow create: if true;
    }
  }
}
