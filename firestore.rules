
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.token.email == "kiosque.du.passage@gmail.com"
      );
    }

    // --- COLLECTION RULES ---

    match /admin_roles/{userId} {
      allow get, list: if isAdmin();
      allow write: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow list, delete: if isAdmin();
    }

    match /listings/{listingId} {
      // Allow everyone to see approved listings or admins to see all
      allow get, list: if (resource == null) || resource.data.status == 'approved' || isAdmin();
      // Only admins can create/update/delete in the master collection
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow get: if isOwner(partnerId) || isAdmin();
      allow create: if isOwner(partnerId);
      allow update: if isOwner(partnerId);
      allow list, delete: if isAdmin();
    }

    match /partners/{partnerId}/listings/{listingId} {
      allow get, list: if isOwner(partnerId) || isAdmin();
      allow write: if isOwner(partnerId) || isAdmin();
    }
  }
}
