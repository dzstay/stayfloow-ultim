rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. FONCTIONS DE SÉCURITÉ PARTAGÉES
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2" || 
        (request.auth.token.email != null && request.auth.token.email.lower() == "stayflow2025@gmail.com") ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "kiosque.du.passage@gmail.com")
      );
    }

    // 2. ACCÈS MAÎTRE (ADMINISTRATION)
    // Règle globale pour l'administrateur
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 3. RÈGLES UTILISATEURS STANDARDS (NON-ADMINS)
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    match /bookings/{bookingId} {
      // SÉPARATION CRITIQUE : allow list (requêtes globales) vs allow get (accès direct)
      // L'admin peut lister toute la collection.
      allow list: if isAdmin();
      // Les utilisateurs ne peuvent lire que leurs propres documents (get).
      allow get: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));
      
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      ));
    }

    match /partners/{partnerId} {
      allow read, write: if isSignedIn() && (request.auth.uid == partnerId || isAdmin());
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /conversations/{convId} {
      // SÉPARATION CRITIQUE : L'admin peut lister toutes les conversations.
      allow list: if isAdmin();
      // Lecture individuelle pour les participants.
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      
      match /messages/{msgId} {
        allow read, create: if isAdmin() || (isSignedIn() && 
          get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid]));
      }
    }
  }
}