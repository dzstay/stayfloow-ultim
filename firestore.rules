
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. DÉTECTION ADMIN MAÎTRE (STRICTE)
    // Synchronisé avec src/lib/admin-config.ts
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "stayflow2025@gmail.com" ||
        request.auth.uid == "G4d04MgUW4fguFOjmhQBbWezheB2"
      );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // ACCÈS PRIORITAIRE ADMIN
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 2. RÈGLES UTILISATEURS
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    match /bookings/{bookingId} {
      // Autorisation de création pour le checkout invité (demandé précédemment)
      allow create: if true; 
      
      // Correction du bug de permission "list" : 
      // On autorise le listage pour tous les utilisateurs connectés.
      // Firestore ne renverra les données que si la requête correspond aux filtres de sécurité.
      // Cela évite l'erreur 403 lors du chargement initial de la collection.
      allow list: if isSignedIn();
      
      // On restreint l'accès direct (get) et la modification aux personnes concernées
      allow get, update: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid
      );
      
      allow delete: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read, write: if isSignedIn() && (request.auth.uid == partnerId || isAdmin());
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /conversations/{convId} {
      // On applique la même correction pour les conversations pour éviter tout blocage futur
      allow list: if isSignedIn();
      allow get, update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      
      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          isAdmin() ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid])
        );
      }
    }
  }
}
